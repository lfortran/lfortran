ifcont3:                                          ; preds = %else2, %then1
  %10 = getelementptr %defs.point2d, %defs.point2d* %2, i32 0, i32 0
  %11 = getelementptr %defs.point2d, %defs.point2d* %3, i32 0, i32 0
