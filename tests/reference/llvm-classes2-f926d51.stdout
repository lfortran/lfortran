declare void @llvm.memset.p0i8.i64(i8* nocapture writeonly, i8, i64, i1 immarg) #1

define linkonce_odr void @_copy_defs_point(i8* %0, i8* %1) {
entry:
  %2 = bitcast i8* %0 to %defs.point*
  %3 = bitcast i8* %1 to %defs.point*
