integer(4), pointer, save :: y
call __module_prif_prif_init(stat)
call c_f_pointer(y__coarray_data, y)
call __module_prif_prif_sync_all()
if (lcompilers_prif_this_image() == 2) then
    call coarrays_16_sub(a1)
    call coarrays_16_sub(b1)
end if
call __module_prif_prif_sync_all()
if (lcompilers_prif_this_image() == 2) then
    write(6, "(*(I4))", iomsg=lfortran_iomsg) a1, b1
    if (a1 /= 1 .or. b1 /= 2) then
        error stop
    end if
end if
call __module_prif_prif_stop(.false.)

