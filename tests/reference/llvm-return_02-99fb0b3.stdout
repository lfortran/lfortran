  %42 = getelementptr %string_descriptor, ptr %stringFormat_desc7, i32 0, i32 0
  store ptr %40, ptr %42, align 8
  %43 = getelementptr %string_descriptor, ptr %stringFormat_desc7, i32 0, i32 1
