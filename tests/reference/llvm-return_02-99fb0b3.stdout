  %39 = alloca i64, align 8
  %40 = call ptr (ptr, i64, ptr, ptr, i32, i32, ...) @_lcompilers_string_format_fortran(ptr null, i64 0, ptr @serialization_info.3, ptr %39, i32 0, i32 0, ptr %c)
  %41 = load i64, ptr %39, align 4
