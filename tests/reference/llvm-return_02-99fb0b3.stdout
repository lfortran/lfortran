  %32 = getelementptr %string_descriptor, ptr %stringFormat_desc4, i32 0, i32 0
  %33 = load ptr, ptr %32, align 8
  %34 = getelementptr %string_descriptor, ptr %stringFormat_desc4, i32 0, i32 1
  %35 = load i64, ptr %34, align 4
