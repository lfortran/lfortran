; ModuleID = 'LFortran'
source_filename = "LFortran"

%complex_4 = type <{ float, float }>
%string_descriptor = type <{ ptr, i64 }>

@0 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@serialization_info = private unnamed_addr constant [8 x i8] c"{R4,R4}\00", align 1
@1 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1
@2 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@serialization_info.1 = private unnamed_addr constant [8 x i8] c"{R4,R4}\00", align 1
@3 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1
@4 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@serialization_info.2 = private unnamed_addr constant [8 x i8] c"{R4,R4}\00", align 1
@5 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1

define i32 @main(i32 %0, ptr %1) {
.entry:
  call void @_lpython_call_initial_functions(i32 %0, ptr %1)
  %x = alloca %complex_4, align 8
  store %complex_4 <{ float 3.000000e+00, float 4.000000e+00 }>, ptr %x, align 1
  %2 = load %complex_4, ptr %x, align 1
  %3 = extractvalue %complex_4 %2, 0
  %4 = extractvalue %complex_4 %2, 1
  %5 = fadd float %3, 4.000000e+00
  %6 = fadd float %4, 0.000000e+00
  %7 = insertvalue %complex_4 undef, float %5, 0
  %8 = insertvalue %complex_4 %7, float %6, 1
  store %complex_4 %8, ptr %x, align 1
  %9 = alloca i64, align 8
  %10 = call ptr (ptr, i64, ptr, ptr, i32, i32, ...) @_lcompilers_string_format_fortran(ptr null, i64 0, ptr @serialization_info, ptr %9, i32 0, i32 0, ptr %x)
  %11 = load i64, ptr %9, align 4
  %stringFormat_desc = alloca %string_descriptor, align 8
  %12 = getelementptr %string_descriptor, ptr %stringFormat_desc, i32 0, i32 0
  store ptr %10, ptr %12, align 8
  %13 = getelementptr %string_descriptor, ptr %stringFormat_desc, i32 0, i32 1
  store i64 %11, ptr %13, align 4
  %14 = getelementptr %string_descriptor, ptr %stringFormat_desc, i32 0, i32 0
  %15 = load ptr, ptr %14, align 8
  %16 = getelementptr %string_descriptor, ptr %stringFormat_desc, i32 0, i32 1
  %17 = load i64, ptr %16, align 4
  %18 = trunc i64 %17 to i32
  call void @_lfortran_printf(ptr @1, ptr %15, i32 %18, ptr @0, i32 1)
  %19 = icmp eq ptr %10, null
  br i1 %19, label %free_done, label %free_nonnull

free_nonnull:                                     ; preds = %.entry
  call void @_lfortran_free(ptr %10)
  br label %free_done

free_done:                                        ; preds = %free_nonnull, %.entry
  %20 = load %complex_4, ptr %x, align 1
  %21 = extractvalue %complex_4 %20, 0
  %22 = extractvalue %complex_4 %20, 1
  %23 = fadd float 2.000000e+00, %21
  %24 = fadd float 0.000000e+00, %22
  %25 = insertvalue %complex_4 undef, float %23, 0
  %26 = insertvalue %complex_4 %25, float %24, 1
  store %complex_4 %26, ptr %x, align 1
  %27 = alloca i64, align 8
  %28 = call ptr (ptr, i64, ptr, ptr, i32, i32, ...) @_lcompilers_string_format_fortran(ptr null, i64 0, ptr @serialization_info.1, ptr %27, i32 0, i32 0, ptr %x)
  %29 = load i64, ptr %27, align 4
  %stringFormat_desc1 = alloca %string_descriptor, align 8
  %30 = getelementptr %string_descriptor, ptr %stringFormat_desc1, i32 0, i32 0
  store ptr %28, ptr %30, align 8
  %31 = getelementptr %string_descriptor, ptr %stringFormat_desc1, i32 0, i32 1
  store i64 %29, ptr %31, align 4
  %32 = getelementptr %string_descriptor, ptr %stringFormat_desc1, i32 0, i32 0
  %33 = load ptr, ptr %32, align 8
  %34 = getelementptr %string_descriptor, ptr %stringFormat_desc1, i32 0, i32 1
  %35 = load i64, ptr %34, align 4
  %36 = trunc i64 %35 to i32
  call void @_lfortran_printf(ptr @3, ptr %33, i32 %36, ptr @2, i32 1)
  %37 = icmp eq ptr %28, null
  br i1 %37, label %free_done3, label %free_nonnull2

free_nonnull2:                                    ; preds = %free_done
  call void @_lfortran_free(ptr %28)
  br label %free_done3

free_done3:                                       ; preds = %free_nonnull2, %free_done
  %38 = load %complex_4, ptr %x, align 1
  %39 = extractvalue %complex_4 %38, 0
  %40 = extractvalue %complex_4 %38, 1
  %41 = fadd float 2.000000e+00, %39
  %42 = fadd float 0.000000e+00, %40
  %43 = insertvalue %complex_4 undef, float %41, 0
  %44 = insertvalue %complex_4 %43, float %42, 1
  %45 = extractvalue %complex_4 %44, 0
  %46 = extractvalue %complex_4 %44, 1
  %47 = fadd float %45, 0.000000e+00
  %48 = fadd float %46, 3.000000e+00
  %49 = insertvalue %complex_4 undef, float %47, 0
  %50 = insertvalue %complex_4 %49, float %48, 1
  store %complex_4 %50, ptr %x, align 1
  %51 = alloca i64, align 8
  %52 = call ptr (ptr, i64, ptr, ptr, i32, i32, ...) @_lcompilers_string_format_fortran(ptr null, i64 0, ptr @serialization_info.2, ptr %51, i32 0, i32 0, ptr %x)
  %53 = load i64, ptr %51, align 4
  %stringFormat_desc4 = alloca %string_descriptor, align 8
  %54 = getelementptr %string_descriptor, ptr %stringFormat_desc4, i32 0, i32 0
  store ptr %52, ptr %54, align 8
  %55 = getelementptr %string_descriptor, ptr %stringFormat_desc4, i32 0, i32 1
  store i64 %53, ptr %55, align 4
  %56 = getelementptr %string_descriptor, ptr %stringFormat_desc4, i32 0, i32 0
  %57 = load ptr, ptr %56, align 8
  %58 = getelementptr %string_descriptor, ptr %stringFormat_desc4, i32 0, i32 1
  %59 = load i64, ptr %58, align 4
  %60 = trunc i64 %59 to i32
  call void @_lfortran_printf(ptr @5, ptr %57, i32 %60, ptr @4, i32 1)
  %61 = icmp eq ptr %52, null
  br i1 %61, label %free_done6, label %free_nonnull5

free_nonnull5:                                    ; preds = %free_done3
  call void @_lfortran_free(ptr %52)
  br label %free_done6

free_done6:                                       ; preds = %free_nonnull5, %free_done3
  call void @_lpython_free_argv()
  br label %return

return:                                           ; preds = %free_done6
  br label %FINALIZE_SYMTABLE_complex2

FINALIZE_SYMTABLE_complex2:                       ; preds = %return
  ret i32 0
}

declare void @_lpython_call_initial_functions(i32, ptr)

declare ptr @_lcompilers_string_format_fortran(ptr, i64, ptr, ptr, i32, i32, ...)

declare void @_lfortran_printf(ptr, ptr, i32, ptr, i32)

declare void @_lfortran_free(ptr)

declare void @_lpython_free_argv()
