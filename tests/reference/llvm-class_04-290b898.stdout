  %32 = getelementptr %foo_c.8, %foo_c.8* %foo, i32 0, i32 0
  %33 = getelementptr %foo_b.7, %foo_b.7* %32, i32 0, i32 0
  %34 = getelementptr %foo_a.4, %foo_a.4* %33, i32 0, i32 0
  %35 = getelementptr %bar_a.3, %bar_a.3* %34, i32 0, i32 0
