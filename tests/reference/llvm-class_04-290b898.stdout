  %81 = getelementptr %bar_b.5, %bar_b.5* %80, i32 0, i32 1
  %82 = load i32, i32* %81, align 4
  %83 = add i32 %78, %82
  %84 = getelementptr %foo_c.8, %foo_c.8* %foo, i32 0, i32 1
  %85 = getelementptr %bar_c.6, %bar_c.6* %84, i32 0, i32 1
  %86 = load i32, i32* %85, align 4
