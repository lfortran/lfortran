  %9 = getelementptr %foo_c.8, %foo_c.8* %foo, i32 0, i32 1
  %10 = getelementptr %bar_c.6, %bar_c.6* %9, i32 0, i32 1
  %11 = getelementptr %bar_c.6, %bar_c.6* %9, i32 0, i32 0
