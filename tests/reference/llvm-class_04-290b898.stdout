  %15 = getelementptr %foo_c.8, %foo_c.8* %foo, i32 0, i32 0
  %16 = getelementptr %foo_b.7, %foo_b.7* %15, i32 0, i32 1
  %17 = getelementptr %bar_b.5, %bar_b.5* %16, i32 0, i32 1
  %18 = getelementptr %bar_b.5, %bar_b.5* %16, i32 0, i32 0
  %19 = getelementptr %bar_a.3, %bar_a.3* %18, i32 0, i32 0
  %20 = getelementptr %foo_b.7, %foo_b.7* %15, i32 0, i32 0
  %21 = getelementptr %foo_a.4, %foo_a.4* %20, i32 0, i32 0
  %22 = getelementptr %bar_a.3, %bar_a.3* %21, i32 0, i32 0
  %23 = getelementptr %foo_c.8, %foo_c.8* %foo, i32 0, i32 0
  %24 = getelementptr %foo_b.7, %foo_b.7* %23, i32 0, i32 0
  %25 = getelementptr %foo_a.4, %foo_a.4* %24, i32 0, i32 0
  %26 = getelementptr %bar_a.3, %bar_a.3* %25, i32 0, i32 0
  store i32 -20, i32* %26, align 4
  %27 = getelementptr %foo_c.8, %foo_c.8* %foo, i32 0, i32 0
  %28 = getelementptr %foo_b.7, %foo_b.7* %27, i32 0, i32 1
  %29 = getelementptr %bar_b.5, %bar_b.5* %28, i32 0, i32 1
