; ModuleID = 'LFortran'
source_filename = "LFortran"

%string_descriptor = type <{ ptr, i64 }>

@c_data = private global [2 x i8] c"BC"
@c = private global %string_descriptor <{ ptr @c_data, i64 2 }>
@string_const_data = private constant [1 x i8] c"A"
@string_const = private global %string_descriptor <{ ptr @string_const_data, i64 1 }>
@string_const_data.1 = private constant [1 x i8] c"Z"
@string_const.2 = private global %string_descriptor <{ ptr @string_const_data.1, i64 1 }>
@string_const_data.3 = private constant [1 x i8] c"a"
@string_const.4 = private global %string_descriptor <{ ptr @string_const_data.3, i64 1 }>
@string_const_data.5 = private constant [1 x i8] c"z"
@string_const.6 = private global %string_descriptor <{ ptr @string_const_data.5, i64 1 }>
@0 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@serialization_info = private unnamed_addr constant [2 x i8] c"L\00", align 1
@1 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1
@string_const_data.7 = private constant [2 x i8] c"@a"
@string_const.8 = private global %string_descriptor <{ ptr @string_const_data.7, i64 2 }>
@string_const_data.9 = private constant [1 x i8] c"A"
@string_const.10 = private global %string_descriptor <{ ptr @string_const_data.9, i64 1 }>
@string_const_data.11 = private constant [1 x i8] c"Z"
@string_const.12 = private global %string_descriptor <{ ptr @string_const_data.11, i64 1 }>
@string_const_data.13 = private constant [1 x i8] c"a"
@string_const.14 = private global %string_descriptor <{ ptr @string_const_data.13, i64 1 }>
@string_const_data.15 = private constant [1 x i8] c"z"
@string_const.16 = private global %string_descriptor <{ ptr @string_const_data.15, i64 1 }>
@2 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@serialization_info.17 = private unnamed_addr constant [2 x i8] c"L\00", align 1
@3 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1
@string_const_data.18 = private constant [2 x i8] c"a@"
@string_const.19 = private global %string_descriptor <{ ptr @string_const_data.18, i64 2 }>
@string_const_data.20 = private constant [1 x i8] c"A"
@string_const.21 = private global %string_descriptor <{ ptr @string_const_data.20, i64 1 }>
@string_const_data.22 = private constant [1 x i8] c"Z"
@string_const.23 = private global %string_descriptor <{ ptr @string_const_data.22, i64 1 }>
@string_const_data.24 = private constant [1 x i8] c"a"
@string_const.25 = private global %string_descriptor <{ ptr @string_const_data.24, i64 1 }>
@string_const_data.26 = private constant [1 x i8] c"z"
@string_const.27 = private global %string_descriptor <{ ptr @string_const_data.26, i64 1 }>
@4 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@serialization_info.28 = private unnamed_addr constant [2 x i8] c"L\00", align 1
@5 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1
@string_const_data.29 = private constant [3 x i8] c"sbs"
@string_const.30 = private global %string_descriptor <{ ptr @string_const_data.29, i64 3 }>
@string_const_data.31 = private constant [3 x i8] c"sbs"
@string_const.32 = private global %string_descriptor <{ ptr @string_const_data.31, i64 3 }>
@"ERROR STOP" = private unnamed_addr constant [11 x i8] c"ERROR STOP\00", align 1
@6 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@7 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1

define i32 @main(i32 %0, ptr %1) {
.entry:
  call void @_lpython_call_initial_functions(i32 %0, ptr %1)
  %is_alpha = alloca i1, align 1
  %num = alloca %string_descriptor, align 8
  store %string_descriptor zeroinitializer, ptr %num, align 1
  %2 = getelementptr %string_descriptor, ptr %num, i32 0, i32 1
  store i64 3, ptr %2, align 4
  %3 = getelementptr %string_descriptor, ptr %num, i32 0, i32 0
  %4 = call ptr @_lfortran_malloc(i64 3)
  store ptr %4, ptr %3, align 8
  %5 = load ptr, ptr @c, align 8
  %6 = load ptr, ptr @string_const, align 8
  %7 = call i32 @str_compare(ptr %5, i64 2, ptr %6, i64 1)
  %8 = icmp sge i32 %7, 0
  %9 = load ptr, ptr @c, align 8
  %10 = load ptr, ptr @string_const.2, align 8
  %11 = call i32 @str_compare(ptr %9, i64 2, ptr %10, i64 1)
  %12 = icmp sle i32 %11, 0
  %13 = icmp eq i1 %8, false
  %14 = select i1 %13, i1 %8, i1 %12
  %15 = load ptr, ptr @c, align 8
  %16 = load ptr, ptr @string_const.4, align 8
  %17 = call i32 @str_compare(ptr %15, i64 2, ptr %16, i64 1)
  %18 = icmp sge i32 %17, 0
  %19 = load ptr, ptr @c, align 8
  %20 = load ptr, ptr @string_const.6, align 8
  %21 = call i32 @str_compare(ptr %19, i64 2, ptr %20, i64 1)
  %22 = icmp sle i32 %21, 0
  %23 = icmp eq i1 %18, false
  %24 = select i1 %23, i1 %18, i1 %22
  %25 = icmp eq i1 %14, false
  %26 = select i1 %25, i1 %24, i1 %14
  store i1 %26, ptr %is_alpha, align 1
  %27 = alloca i64, align 8
  %28 = call ptr (ptr, i64, ptr, ptr, i32, i32, ...) @_lcompilers_string_format_fortran(ptr null, i64 0, ptr @serialization_info, ptr %27, i32 0, i32 0, ptr %is_alpha)
  %29 = load i64, ptr %27, align 4
  %stringFormat_desc = alloca %string_descriptor, align 8
  %30 = getelementptr %string_descriptor, ptr %stringFormat_desc, i32 0, i32 0
  store ptr %28, ptr %30, align 8
  %31 = getelementptr %string_descriptor, ptr %stringFormat_desc, i32 0, i32 1
  store i64 %29, ptr %31, align 4
  %32 = getelementptr %string_descriptor, ptr %stringFormat_desc, i32 0, i32 0
  %33 = load ptr, ptr %32, align 8
  %34 = getelementptr %string_descriptor, ptr %stringFormat_desc, i32 0, i32 1
  %35 = load i64, ptr %34, align 4
  %36 = trunc i64 %35 to i32
  call void @_lfortran_printf(ptr @1, ptr %33, i32 %36, ptr @0, i32 1)
  %37 = icmp eq ptr %28, null
  br i1 %37, label %free_done, label %free_nonnull

free_nonnull:                                     ; preds = %.entry
  call void @_lfortran_free(ptr %28)
  br label %free_done

free_done:                                        ; preds = %free_nonnull, %.entry
  %38 = load ptr, ptr @string_const.8, align 8
  call void @_lfortran_strcpy(ptr @c, ptr getelementptr inbounds (%string_descriptor, ptr @c, i32 0, i32 1), i8 0, i8 0, ptr %38, i64 2)
  %39 = load ptr, ptr @c, align 8
  %40 = load ptr, ptr @string_const.10, align 8
  %41 = call i32 @str_compare(ptr %39, i64 2, ptr %40, i64 1)
  %42 = icmp sge i32 %41, 0
  %43 = load ptr, ptr @c, align 8
  %44 = load ptr, ptr @string_const.12, align 8
  %45 = call i32 @str_compare(ptr %43, i64 2, ptr %44, i64 1)
  %46 = icmp sle i32 %45, 0
  %47 = icmp eq i1 %42, false
  %48 = select i1 %47, i1 %42, i1 %46
  %49 = load ptr, ptr @c, align 8
  %50 = load ptr, ptr @string_const.14, align 8
  %51 = call i32 @str_compare(ptr %49, i64 2, ptr %50, i64 1)
  %52 = icmp sge i32 %51, 0
  %53 = load ptr, ptr @c, align 8
  %54 = load ptr, ptr @string_const.16, align 8
  %55 = call i32 @str_compare(ptr %53, i64 2, ptr %54, i64 1)
  %56 = icmp sle i32 %55, 0
  %57 = icmp eq i1 %52, false
  %58 = select i1 %57, i1 %52, i1 %56
  %59 = icmp eq i1 %48, false
  %60 = select i1 %59, i1 %58, i1 %48
  store i1 %60, ptr %is_alpha, align 1
  %61 = alloca i64, align 8
  %62 = call ptr (ptr, i64, ptr, ptr, i32, i32, ...) @_lcompilers_string_format_fortran(ptr null, i64 0, ptr @serialization_info.17, ptr %61, i32 0, i32 0, ptr %is_alpha)
  %63 = load i64, ptr %61, align 4
  %stringFormat_desc1 = alloca %string_descriptor, align 8
  %64 = getelementptr %string_descriptor, ptr %stringFormat_desc1, i32 0, i32 0
  store ptr %62, ptr %64, align 8
  %65 = getelementptr %string_descriptor, ptr %stringFormat_desc1, i32 0, i32 1
  store i64 %63, ptr %65, align 4
  %66 = getelementptr %string_descriptor, ptr %stringFormat_desc1, i32 0, i32 0
  %67 = load ptr, ptr %66, align 8
  %68 = getelementptr %string_descriptor, ptr %stringFormat_desc1, i32 0, i32 1
  %69 = load i64, ptr %68, align 4
  %70 = trunc i64 %69 to i32
  call void @_lfortran_printf(ptr @3, ptr %67, i32 %70, ptr @2, i32 1)
  %71 = icmp eq ptr %62, null
  br i1 %71, label %free_done3, label %free_nonnull2

free_nonnull2:                                    ; preds = %free_done
  call void @_lfortran_free(ptr %62)
  br label %free_done3

free_done3:                                       ; preds = %free_nonnull2, %free_done
  %72 = load ptr, ptr @string_const.19, align 8
  call void @_lfortran_strcpy(ptr @c, ptr getelementptr inbounds (%string_descriptor, ptr @c, i32 0, i32 1), i8 0, i8 0, ptr %72, i64 2)
  %73 = load ptr, ptr @c, align 8
  %74 = load ptr, ptr @string_const.21, align 8
  %75 = call i32 @str_compare(ptr %73, i64 2, ptr %74, i64 1)
  %76 = icmp sge i32 %75, 0
  %77 = load ptr, ptr @c, align 8
  %78 = load ptr, ptr @string_const.23, align 8
  %79 = call i32 @str_compare(ptr %77, i64 2, ptr %78, i64 1)
  %80 = icmp sle i32 %79, 0
  %81 = icmp eq i1 %76, false
  %82 = select i1 %81, i1 %76, i1 %80
  %83 = load ptr, ptr @c, align 8
  %84 = load ptr, ptr @string_const.25, align 8
  %85 = call i32 @str_compare(ptr %83, i64 2, ptr %84, i64 1)
  %86 = icmp sge i32 %85, 0
  %87 = load ptr, ptr @c, align 8
  %88 = load ptr, ptr @string_const.27, align 8
  %89 = call i32 @str_compare(ptr %87, i64 2, ptr %88, i64 1)
  %90 = icmp sle i32 %89, 0
  %91 = icmp eq i1 %86, false
  %92 = select i1 %91, i1 %86, i1 %90
  %93 = icmp eq i1 %82, false
  %94 = select i1 %93, i1 %92, i1 %82
  store i1 %94, ptr %is_alpha, align 1
  %95 = alloca i64, align 8
  %96 = call ptr (ptr, i64, ptr, ptr, i32, i32, ...) @_lcompilers_string_format_fortran(ptr null, i64 0, ptr @serialization_info.28, ptr %95, i32 0, i32 0, ptr %is_alpha)
  %97 = load i64, ptr %95, align 4
  %stringFormat_desc4 = alloca %string_descriptor, align 8
  %98 = getelementptr %string_descriptor, ptr %stringFormat_desc4, i32 0, i32 0
  store ptr %96, ptr %98, align 8
  %99 = getelementptr %string_descriptor, ptr %stringFormat_desc4, i32 0, i32 1
  store i64 %97, ptr %99, align 4
  %100 = getelementptr %string_descriptor, ptr %stringFormat_desc4, i32 0, i32 0
  %101 = load ptr, ptr %100, align 8
  %102 = getelementptr %string_descriptor, ptr %stringFormat_desc4, i32 0, i32 1
  %103 = load i64, ptr %102, align 4
  %104 = trunc i64 %103 to i32
  call void @_lfortran_printf(ptr @5, ptr %101, i32 %104, ptr @4, i32 1)
  %105 = icmp eq ptr %96, null
  br i1 %105, label %free_done6, label %free_nonnull5

free_nonnull5:                                    ; preds = %free_done3
  call void @_lfortran_free(ptr %96)
  br label %free_done6

free_done6:                                       ; preds = %free_nonnull5, %free_done3
  %106 = getelementptr %string_descriptor, ptr %num, i32 0, i32 0
  %107 = load ptr, ptr %106, align 8
  %StrSliceGEP = getelementptr i8, ptr %107, i64 0
  %StrSlice_StrView = alloca %string_descriptor, align 8
  %108 = getelementptr %string_descriptor, ptr %StrSlice_StrView, i32 0, i32 0
  store ptr %StrSliceGEP, ptr %108, align 8
  %109 = getelementptr %string_descriptor, ptr %StrSlice_StrView, i32 0, i32 1
  store i64 3, ptr %109, align 4
  %110 = getelementptr %string_descriptor, ptr %StrSlice_StrView, i32 0, i32 0
  %111 = getelementptr %string_descriptor, ptr %StrSlice_StrView, i32 0, i32 1
  %112 = load ptr, ptr @string_const.30, align 8
  call void @_lfortran_strcpy(ptr %110, ptr %111, i8 0, i8 0, ptr %112, i64 3)
  %113 = getelementptr %string_descriptor, ptr %num, i32 0, i32 0
  %114 = load ptr, ptr %113, align 8
  %115 = load ptr, ptr @string_const.32, align 8
  %116 = call i32 @str_compare(ptr %114, i64 3, ptr %115, i64 3)
  %117 = icmp ne i32 %116, 0
  br i1 %117, label %then, label %else

then:                                             ; preds = %free_done6
  call void (ptr, ...) @_lcompilers_print_error(ptr @7, ptr @"ERROR STOP", ptr @6)
  call void @exit(i32 1)
  br label %ifcont

else:                                             ; preds = %free_done6
  br label %ifcont

ifcont:                                           ; preds = %else, %then
  call void @_lpython_free_argv()
  br label %return

return:                                           ; preds = %ifcont
  br label %FINALIZE_SYMTABLE_string_10

FINALIZE_SYMTABLE_string_10:                      ; preds = %return
  br label %Finalize_Variable_num

Finalize_Variable_num:                            ; preds = %FINALIZE_SYMTABLE_string_10
  %118 = getelementptr %string_descriptor, ptr %num, i32 0, i32 0
  %119 = load ptr, ptr %118, align 8
  %120 = icmp eq ptr %119, null
  br i1 %120, label %free_done8, label %free_nonnull7

free_nonnull7:                                    ; preds = %Finalize_Variable_num
  call void @_lfortran_free(ptr %119)
  br label %free_done8

free_done8:                                       ; preds = %free_nonnull7, %Finalize_Variable_num
  ret i32 0
}

declare void @_lpython_call_initial_functions(i32, ptr)

declare ptr @_lfortran_malloc(i64)

declare i32 @str_compare(ptr, i64, ptr, i64)

declare ptr @_lcompilers_string_format_fortran(ptr, i64, ptr, ptr, i32, i32, ...)

declare void @_lfortran_printf(ptr, ptr, i32, ptr, i32)

declare void @_lfortran_free(ptr)

declare void @_lfortran_strcpy(ptr, ptr, i8, i8, ptr, i64)

declare void @_lcompilers_print_error(ptr, ...)

declare void @exit(i32)

declare void @_lpython_free_argv()
