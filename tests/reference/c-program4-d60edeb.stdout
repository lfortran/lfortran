
#include <stdlib.h>
#include <stdbool.h>
#include <stdio.h>
#include <string.h>
#include <lfortran_intrinsics.h>

float func1(float a, float b);
float func2(float a, float b);



// Implementations
float func1(float a, float b)
{
    float c;
    static float saved = 2;
    saved = saved + 1;
    c = c + a + b + saved;
    return c;
}

float func2(float a, float b)
{
    float c;
    float d;
    static float saved1 = 2;
    static float saved2;
    saved1 = saved1 + 1;
    c = d + c + a + b + saved1 + saved2;
    saved2 = saved2 + 1;
    d = d + 3;
    return c;
}

int main(int argc, char* argv[])
{
    _lpython_set_argv(argc, argv);
    float x;
    float y;
    float z;
    x = 1;
    y = 2;
    z = func1(x, y);
    printf("%s%s%f\n", "6.0 == ", " ", z);
    z = func1(x, y);
    printf("%s%s%f\n", "7.0 == ", " ", z);
    z = func2(x, y);
    printf("%s%s%f\n", "6.0 == ", " ", z);
    z = func2(x, y);
    printf("%s%s%f\n", "8.0 == ", " ", z);
    return 0;
}
