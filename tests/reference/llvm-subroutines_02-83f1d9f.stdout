; ModuleID = 'LFortran'
source_filename = "LFortran"

%string_descriptor = type <{ ptr, i64 }>

@0 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@serialization_info = private unnamed_addr constant [6 x i8] c"I4,I4\00", align 1
@1 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1
@"ERROR STOP" = private unnamed_addr constant [11 x i8] c"ERROR STOP\00", align 1
@2 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@3 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1
@4 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@5 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1
@6 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@serialization_info.1 = private unnamed_addr constant [6 x i8] c"I4,I4\00", align 1
@7 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1
@8 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@9 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1
@10 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@11 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1
@12 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@serialization_info.2 = private unnamed_addr constant [6 x i8] c"I4,I4\00", align 1
@13 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1
@14 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@15 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1
@16 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@17 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1

define i32 @main(i32 %0, ptr %1) {
.entry:
  call void @_lpython_call_initial_functions(i32 %0, ptr %1)
  %i = alloca i32, align 4
  %j = alloca i32, align 4
  store i32 1, ptr %i, align 4
  store i32 1, ptr %j, align 4
  call void @f(ptr %i, ptr %j)
  %2 = alloca i64, align 8
  %3 = call ptr (ptr, i64, ptr, ptr, i32, i32, ...) @_lcompilers_string_format_fortran(ptr null, i64 0, ptr @serialization_info, ptr %2, i32 0, i32 0, ptr %i, ptr %j)
  %4 = load i64, ptr %2, align 4
  %stringFormat_desc = alloca %string_descriptor, align 8
  %5 = getelementptr %string_descriptor, ptr %stringFormat_desc, i32 0, i32 0
  store ptr %3, ptr %5, align 8
  %6 = getelementptr %string_descriptor, ptr %stringFormat_desc, i32 0, i32 1
  store i64 %4, ptr %6, align 4
  %7 = getelementptr %string_descriptor, ptr %stringFormat_desc, i32 0, i32 0
  %8 = load ptr, ptr %7, align 8
  %9 = getelementptr %string_descriptor, ptr %stringFormat_desc, i32 0, i32 1
  %10 = load i64, ptr %9, align 4
  %11 = trunc i64 %10 to i32
  call void @_lfortran_printf(ptr @1, ptr %8, i32 %11, ptr @0, i32 1)
  %12 = icmp eq ptr %3, null
  br i1 %12, label %free_done, label %free_nonnull

free_nonnull:                                     ; preds = %.entry
  call void @_lfortran_free(ptr %3)
  br label %free_done

free_done:                                        ; preds = %free_nonnull, %.entry
  %13 = load i32, ptr %i, align 4
  %14 = icmp ne i32 %13, 1
  br i1 %14, label %then, label %else

then:                                             ; preds = %free_done
  call void (ptr, ...) @_lcompilers_print_error(ptr @3, ptr @"ERROR STOP", ptr @2)
  call void @exit(i32 1)
  br label %ifcont

else:                                             ; preds = %free_done
  br label %ifcont

ifcont:                                           ; preds = %else, %then
  %15 = load i32, ptr %j, align 4
  %16 = icmp ne i32 %15, 2
  br i1 %16, label %then1, label %else2

then1:                                            ; preds = %ifcont
  call void (ptr, ...) @_lcompilers_print_error(ptr @5, ptr @"ERROR STOP", ptr @4)
  call void @exit(i32 1)
  br label %ifcont3

else2:                                            ; preds = %ifcont
  br label %ifcont3

ifcont3:                                          ; preds = %else2, %then1
  call void @g(ptr %i, ptr %j)
  %17 = alloca i64, align 8
  %18 = call ptr (ptr, i64, ptr, ptr, i32, i32, ...) @_lcompilers_string_format_fortran(ptr null, i64 0, ptr @serialization_info.1, ptr %17, i32 0, i32 0, ptr %i, ptr %j)
  %19 = load i64, ptr %17, align 4
  %stringFormat_desc4 = alloca %string_descriptor, align 8
  %20 = getelementptr %string_descriptor, ptr %stringFormat_desc4, i32 0, i32 0
  store ptr %18, ptr %20, align 8
  %21 = getelementptr %string_descriptor, ptr %stringFormat_desc4, i32 0, i32 1
  store i64 %19, ptr %21, align 4
  %22 = getelementptr %string_descriptor, ptr %stringFormat_desc4, i32 0, i32 0
  %23 = load ptr, ptr %22, align 8
  %24 = getelementptr %string_descriptor, ptr %stringFormat_desc4, i32 0, i32 1
  %25 = load i64, ptr %24, align 4
  %26 = trunc i64 %25 to i32
  call void @_lfortran_printf(ptr @7, ptr %23, i32 %26, ptr @6, i32 1)
  %27 = icmp eq ptr %18, null
  br i1 %27, label %free_done6, label %free_nonnull5

free_nonnull5:                                    ; preds = %ifcont3
  call void @_lfortran_free(ptr %18)
  br label %free_done6

free_done6:                                       ; preds = %free_nonnull5, %ifcont3
  %28 = load i32, ptr %i, align 4
  %29 = icmp ne i32 %28, 1
  br i1 %29, label %then7, label %else8

then7:                                            ; preds = %free_done6
  call void (ptr, ...) @_lcompilers_print_error(ptr @9, ptr @"ERROR STOP", ptr @8)
  call void @exit(i32 1)
  br label %ifcont9

else8:                                            ; preds = %free_done6
  br label %ifcont9

ifcont9:                                          ; preds = %else8, %then7
  %30 = load i32, ptr %j, align 4
  %31 = icmp ne i32 %30, 0
  br i1 %31, label %then10, label %else11

then10:                                           ; preds = %ifcont9
  call void (ptr, ...) @_lcompilers_print_error(ptr @11, ptr @"ERROR STOP", ptr @10)
  call void @exit(i32 1)
  br label %ifcont12

else11:                                           ; preds = %ifcont9
  br label %ifcont12

ifcont12:                                         ; preds = %else11, %then10
  call void @h(ptr %i, ptr %j)
  %32 = alloca i64, align 8
  %33 = call ptr (ptr, i64, ptr, ptr, i32, i32, ...) @_lcompilers_string_format_fortran(ptr null, i64 0, ptr @serialization_info.2, ptr %32, i32 0, i32 0, ptr %i, ptr %j)
  %34 = load i64, ptr %32, align 4
  %stringFormat_desc13 = alloca %string_descriptor, align 8
  %35 = getelementptr %string_descriptor, ptr %stringFormat_desc13, i32 0, i32 0
  store ptr %33, ptr %35, align 8
  %36 = getelementptr %string_descriptor, ptr %stringFormat_desc13, i32 0, i32 1
  store i64 %34, ptr %36, align 4
  %37 = getelementptr %string_descriptor, ptr %stringFormat_desc13, i32 0, i32 0
  %38 = load ptr, ptr %37, align 8
  %39 = getelementptr %string_descriptor, ptr %stringFormat_desc13, i32 0, i32 1
  %40 = load i64, ptr %39, align 4
  %41 = trunc i64 %40 to i32
  call void @_lfortran_printf(ptr @13, ptr %38, i32 %41, ptr @12, i32 1)
  %42 = icmp eq ptr %33, null
  br i1 %42, label %free_done15, label %free_nonnull14

free_nonnull14:                                   ; preds = %ifcont12
  call void @_lfortran_free(ptr %33)
  br label %free_done15

free_done15:                                      ; preds = %free_nonnull14, %ifcont12
  %43 = load i32, ptr %i, align 4
  %44 = icmp ne i32 %43, 1
  br i1 %44, label %then16, label %else17

then16:                                           ; preds = %free_done15
  call void (ptr, ...) @_lcompilers_print_error(ptr @15, ptr @"ERROR STOP", ptr @14)
  call void @exit(i32 1)
  br label %ifcont18

else17:                                           ; preds = %free_done15
  br label %ifcont18

ifcont18:                                         ; preds = %else17, %then16
  %45 = load i32, ptr %j, align 4
  %46 = icmp ne i32 %45, 0
  br i1 %46, label %then19, label %else20

then19:                                           ; preds = %ifcont18
  call void (ptr, ...) @_lcompilers_print_error(ptr @17, ptr @"ERROR STOP", ptr @16)
  call void @exit(i32 1)
  br label %ifcont21

else20:                                           ; preds = %ifcont18
  br label %ifcont21

ifcont21:                                         ; preds = %else20, %then19
  call void @_lpython_free_argv()
  br label %return

return:                                           ; preds = %ifcont21
  br label %FINALIZE_SYMTABLE_subroutines_02

FINALIZE_SYMTABLE_subroutines_02:                 ; preds = %return
  ret i32 0
}

define void @f(ptr %a, ptr %b) {
.entry:
  %0 = load i32, ptr %a, align 4
  %1 = add i32 %0, 1
  store i32 %1, ptr %b, align 4
  br label %return

return:                                           ; preds = %.entry
  br label %FINALIZE_SYMTABLE_f

FINALIZE_SYMTABLE_f:                              ; preds = %return
  ret void
}

define void @g(ptr %a, ptr %b) {
.entry:
  %0 = load i32, ptr %a, align 4
  %1 = sub i32 %0, 1
  store i32 %1, ptr %b, align 4
  br label %return

return:                                           ; preds = %.entry
  br label %FINALIZE_SYMTABLE_g

FINALIZE_SYMTABLE_g:                              ; preds = %return
  ret void
}

define void @h(ptr %a, ptr %b) {
.entry:
  call void @g(ptr %a, ptr %b)
  br label %return

return:                                           ; preds = %.entry
  br label %FINALIZE_SYMTABLE_h

FINALIZE_SYMTABLE_h:                              ; preds = %return
  ret void
}

declare void @_lpython_call_initial_functions(i32, ptr)

declare ptr @_lcompilers_string_format_fortran(ptr, i64, ptr, ptr, i32, i32, ...)

declare void @_lfortran_printf(ptr, ptr, i32, ptr, i32)

declare void @_lfortran_free(ptr)

declare void @_lcompilers_print_error(ptr, ...)

declare void @exit(i32)

declare void @_lpython_free_argv()
