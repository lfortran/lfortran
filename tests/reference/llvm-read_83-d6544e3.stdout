  call void @exit(i32 1)
  br label %ifcont

else:                                             ; preds = %.entry
  br label %ifcont

ifcont:                                           ; preds = %else, %then
  %7 = getelementptr %string_descriptor, ptr %command_argument_holder, i32 0, i32 0
