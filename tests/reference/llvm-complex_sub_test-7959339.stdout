; ModuleID = 'LFortran'
source_filename = "LFortran"

%complex_4 = type <{ float, float }>
%string_descriptor = type <{ ptr, i64 }>

@0 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@serialization_info = private unnamed_addr constant [8 x i8] c"{R4,R4}\00", align 1
@1 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1
@2 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@serialization_info.1 = private unnamed_addr constant [8 x i8] c"{R4,R4}\00", align 1
@3 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1
@4 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@serialization_info.2 = private unnamed_addr constant [8 x i8] c"{R4,R4}\00", align 1
@5 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1

define i32 @main(i32 %0, ptr %1) {
.entry:
  call void @_lpython_call_initial_functions(i32 %0, ptr %1)
  %x = alloca %complex_4, align 8
  store %complex_4 <{ float 3.000000e+00, float 4.000000e+00 }>, ptr %x, align 1
  %2 = load %complex_4, ptr %x, align 1
  %3 = extractvalue %complex_4 %2, 0
  %4 = extractvalue %complex_4 %2, 1
  %5 = fsub float %3, 4.000000e+00
  %6 = fsub float %4, 0.000000e+00
  %7 = insertvalue %complex_4 undef, float %5, 0
  %8 = insertvalue %complex_4 %7, float %6, 1
  store %complex_4 %8, ptr %x, align 1
  %9 = load %complex_4, ptr %x, align 1
  %10 = extractvalue %complex_4 %9, 0
  %11 = extractvalue %complex_4 %9, 1
  %12 = fsub float 4.000000e+00, %10
  %13 = fsub float 0.000000e+00, %11
  %14 = insertvalue %complex_4 undef, float %12, 0
  %15 = insertvalue %complex_4 %14, float %13, 1
  store %complex_4 %15, ptr %x, align 1
  %16 = alloca i64, align 8
  %17 = call ptr (ptr, i64, ptr, ptr, i32, i32, ...) @_lcompilers_string_format_fortran(ptr null, i64 0, ptr @serialization_info, ptr %16, i32 0, i32 0, ptr %x)
  %18 = load i64, ptr %16, align 4
  %stringFormat_desc = alloca %string_descriptor, align 8
  %19 = getelementptr %string_descriptor, ptr %stringFormat_desc, i32 0, i32 0
  store ptr %17, ptr %19, align 8
  %20 = getelementptr %string_descriptor, ptr %stringFormat_desc, i32 0, i32 1
  store i64 %18, ptr %20, align 4
  %21 = getelementptr %string_descriptor, ptr %stringFormat_desc, i32 0, i32 0
  %22 = load ptr, ptr %21, align 8
  %23 = getelementptr %string_descriptor, ptr %stringFormat_desc, i32 0, i32 1
  %24 = load i64, ptr %23, align 4
  %25 = trunc i64 %24 to i32
  call void @_lfortran_printf(ptr @1, ptr %22, i32 %25, ptr @0, i32 1)
  %26 = icmp eq ptr %17, null
  br i1 %26, label %free_done, label %free_nonnull

free_nonnull:                                     ; preds = %.entry
  call void @_lfortran_free(ptr %17)
  br label %free_done

free_done:                                        ; preds = %free_nonnull, %.entry
  %27 = load %complex_4, ptr %x, align 1
  %28 = extractvalue %complex_4 %27, 0
  %29 = extractvalue %complex_4 %27, 1
  %30 = fsub float 2.000000e+00, %28
  %31 = fsub float 0.000000e+00, %29
  %32 = insertvalue %complex_4 undef, float %30, 0
  %33 = insertvalue %complex_4 %32, float %31, 1
  store %complex_4 %33, ptr %x, align 1
  %34 = alloca i64, align 8
  %35 = call ptr (ptr, i64, ptr, ptr, i32, i32, ...) @_lcompilers_string_format_fortran(ptr null, i64 0, ptr @serialization_info.1, ptr %34, i32 0, i32 0, ptr %x)
  %36 = load i64, ptr %34, align 4
  %stringFormat_desc1 = alloca %string_descriptor, align 8
  %37 = getelementptr %string_descriptor, ptr %stringFormat_desc1, i32 0, i32 0
  store ptr %35, ptr %37, align 8
  %38 = getelementptr %string_descriptor, ptr %stringFormat_desc1, i32 0, i32 1
  store i64 %36, ptr %38, align 4
  %39 = getelementptr %string_descriptor, ptr %stringFormat_desc1, i32 0, i32 0
  %40 = load ptr, ptr %39, align 8
  %41 = getelementptr %string_descriptor, ptr %stringFormat_desc1, i32 0, i32 1
  %42 = load i64, ptr %41, align 4
  %43 = trunc i64 %42 to i32
  call void @_lfortran_printf(ptr @3, ptr %40, i32 %43, ptr @2, i32 1)
  %44 = icmp eq ptr %35, null
  br i1 %44, label %free_done3, label %free_nonnull2

free_nonnull2:                                    ; preds = %free_done
  call void @_lfortran_free(ptr %35)
  br label %free_done3

free_done3:                                       ; preds = %free_nonnull2, %free_done
  %45 = load %complex_4, ptr %x, align 1
  %46 = extractvalue %complex_4 %45, 0
  %47 = extractvalue %complex_4 %45, 1
  %48 = fsub float %46, 0.000000e+00
  %49 = fsub float %47, 3.000000e+00
  %50 = insertvalue %complex_4 undef, float %48, 0
  %51 = insertvalue %complex_4 %50, float %49, 1
  store %complex_4 %51, ptr %x, align 1
  %52 = alloca i64, align 8
  %53 = call ptr (ptr, i64, ptr, ptr, i32, i32, ...) @_lcompilers_string_format_fortran(ptr null, i64 0, ptr @serialization_info.2, ptr %52, i32 0, i32 0, ptr %x)
  %54 = load i64, ptr %52, align 4
  %stringFormat_desc4 = alloca %string_descriptor, align 8
  %55 = getelementptr %string_descriptor, ptr %stringFormat_desc4, i32 0, i32 0
  store ptr %53, ptr %55, align 8
  %56 = getelementptr %string_descriptor, ptr %stringFormat_desc4, i32 0, i32 1
  store i64 %54, ptr %56, align 4
  %57 = getelementptr %string_descriptor, ptr %stringFormat_desc4, i32 0, i32 0
  %58 = load ptr, ptr %57, align 8
  %59 = getelementptr %string_descriptor, ptr %stringFormat_desc4, i32 0, i32 1
  %60 = load i64, ptr %59, align 4
  %61 = trunc i64 %60 to i32
  call void @_lfortran_printf(ptr @5, ptr %58, i32 %61, ptr @4, i32 1)
  %62 = icmp eq ptr %53, null
  br i1 %62, label %free_done6, label %free_nonnull5

free_nonnull5:                                    ; preds = %free_done3
  call void @_lfortran_free(ptr %53)
  br label %free_done6

free_done6:                                       ; preds = %free_nonnull5, %free_done3
  call void @_lpython_free_argv()
  br label %return

return:                                           ; preds = %free_done6
  br label %FINALIZE_SYMTABLE_complex2

FINALIZE_SYMTABLE_complex2:                       ; preds = %return
  ret i32 0
}

declare void @_lpython_call_initial_functions(i32, ptr)

declare ptr @_lcompilers_string_format_fortran(ptr, i64, ptr, ptr, i32, i32, ...)

declare void @_lfortran_printf(ptr, ptr, i32, ptr, i32)

declare void @_lfortran_free(ptr)

declare void @_lpython_free_argv()
