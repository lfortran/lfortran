}

define internal void @finalize_descriptorArray_Array_1_i32(ptr %0) {
entry:
  %1 = call ptr @_lfortran_get_default_allocator()
  %2 = getelementptr %array.1, ptr %0, i32 0, i32 0
  %3 = load ptr, ptr %2, align 8
  %4 = ptrtoint ptr %3 to i64
