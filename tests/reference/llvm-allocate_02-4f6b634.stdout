  %23 = getelementptr { ptr, i32, i32, i32, i32 }, ptr %20, i32 0, i32 2
  store i32 14, ptr %23, align 4
  %24 = getelementptr { ptr, i32, i32, i32, i32 }, ptr %20, i32 0, i32 3
