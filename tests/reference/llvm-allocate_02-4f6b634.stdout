  store i64 1, ptr %92, align 8
  %93 = getelementptr %array.1, ptr %84, i32 0, i32 0
  %94 = call ptr @_lfortran_get_default_allocator()
  %95 = call ptr @_lfortran_malloc_alloc(ptr %94, i64 4)
