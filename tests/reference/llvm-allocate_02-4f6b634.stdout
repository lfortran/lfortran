define i32 @main(i32 %0, ptr %1) {
.entry:
  %2 = call ptr @_lfortran_get_default_allocator()
  %arr_desc = alloca %array.1, align 8
  call void @_lpython_call_initial_functions(i32 %0, ptr %1)
  %arr = alloca ptr, align 8
