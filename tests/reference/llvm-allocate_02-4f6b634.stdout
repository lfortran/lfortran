; ModuleID = 'LFortran'
source_filename = "LFortran"
target datalayout = "..."

%array.1 = type { ptr, i64, i32, i8, i8, i8, i8, i64, [1 x %dimension_descriptor] }
%dimension_descriptor = type { i64, i64, i64 }

@0 = private unnamed_addr constant [4 x i8] c"arr\00", align 1
@1 = private unnamed_addr constant [22 x i8] c"tests/allocate_02.f90\00", align 1
@2 = private unnamed_addr constant [53 x i8] c"Cannot allocate '%s' because it is already allocated\00", align 1
