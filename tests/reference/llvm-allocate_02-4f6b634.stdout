declare void @_lpython_call_initial_functions(i32, ptr)

declare ptr @_lcompilers_snprintf_alloc(ptr, ptr, ...)

declare ptr @_lfortran_get_default_allocator()

declare void @_lcompilers_runtime_error(ptr, ptr, i32, ptr, ...)

