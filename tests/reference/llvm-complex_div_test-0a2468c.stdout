free_done:                                        ; preds = %free_nonnull, %complex_div_cont
  %38 = load %complex_4, %complex_4* %x, align 1
  %39 = extractvalue %complex_4 %38, 0
  %40 = extractvalue %complex_4 %38, 1
  %41 = call float @llvm.fabs.f32(float %39)
  %42 = call float @llvm.fabs.f32(float %40)
  %43 = fcmp oge float %41, %42
  br i1 %43, label %complex_div_r_ge_s1, label %complex_div_r_lt_s2

complex_div_r_ge_s1:                              ; preds = %free_done
  %44 = fdiv float %40, %39
  %45 = fmul float %40, %44
  %46 = fadd float %39, %45
  %47 = fmul float 0.000000e+00, %44
  %48 = fadd float 2.000000e+00, %47
  %49 = fmul float 2.000000e+00, %44
  %50 = fsub float 0.000000e+00, %49
  %51 = fdiv float %48, %46
  %52 = fdiv float %50, %46
  br label %complex_div_cont3

complex_div_r_lt_s2:                              ; preds = %free_done
  %53 = fdiv float %39, %40
  %54 = fmul float %39, %53
  %55 = fadd float %40, %54
  %56 = fmul float 2.000000e+00, %53
  %57 = fadd float %56, 0.000000e+00
  %58 = fmul float 0.000000e+00, %53
  %59 = fsub float %58, 2.000000e+00
  %60 = fdiv float %57, %55
  %61 = fdiv float %59, %55
  br label %complex_div_cont3

complex_div_cont3:                                ; preds = %complex_div_r_lt_s2, %complex_div_r_ge_s1
  %62 = phi float [ %51, %complex_div_r_ge_s1 ], [ %60, %complex_div_r_lt_s2 ]
  %63 = phi float [ %52, %complex_div_r_ge_s1 ], [ %61, %complex_div_r_lt_s2 ]
  %64 = insertvalue %complex_4 undef, float %62, 0
  %65 = insertvalue %complex_4 %64, float %63, 1
  store %complex_4 %65, %complex_4* %x, align 1
  %66 = call i8* (i8*, i8*, i64, i8*, i64*, i32, i32, i32, i32, i32, ...) @_lcompilers_string_format_fortran(i8* %4, i8* null, i64 0, i8* getelementptr inbounds ([8 x i8], [8 x i8]* @serialization_info.1, i32 0, i32 0), i64* %3, i32 0, i32 0, i32 0, i32 0, i32 0, %complex_4* %x)
  %67 = load i64, i64* %3, align 8
  %68 = getelementptr %string_descriptor, %string_descriptor* %stringFormat_desc4, i32 0, i32 0
  store i8* %66, i8** %68, align 8
  %69 = getelementptr %string_descriptor, %string_descriptor* %stringFormat_desc4, i32 0, i32 1
  store i64 %67, i64* %69, align 8
  %70 = getelementptr %string_descriptor, %string_descriptor* %stringFormat_desc4, i32 0, i32 0
  %71 = load i8*, i8** %70, align 8
  %72 = getelementptr %string_descriptor, %string_descriptor* %stringFormat_desc4, i32 0, i32 1
  %73 = load i64, i64* %72, align 8
  %74 = trunc i64 %73 to i32
  call void @_lfortran_printf(i8* getelementptr inbounds ([5 x i8], [5 x i8]* @3, i32 0, i32 0), i8* %71, i32 %74, i8* getelementptr inbounds ([2 x i8], [2 x i8]* @2, i32 0, i32 0), i32 1)
  %75 = icmp eq i8* %66, null
  br i1 %75, label %free_done6, label %free_nonnull5

free_nonnull5:                                    ; preds = %complex_div_cont3
  call void @_lfortran_free_alloc(i8* %4, i8* %66)
  br label %free_done6

free_done6:                                       ; preds = %free_nonnull5, %complex_div_cont3
  %76 = load %complex_4, %complex_4* %x, align 1
  %77 = extractvalue %complex_4 %76, 0
  %78 = extractvalue %complex_4 %76, 1
  %79 = fadd float %77, 0.000000e+00
  %80 = fadd float %78, 3.000000e+00
  %81 = insertvalue %complex_4 undef, float %79, 0
  %82 = insertvalue %complex_4 %81, float %80, 1
  %83 = extractvalue %complex_4 %82, 0
  %84 = extractvalue %complex_4 %82, 1
  %85 = call float @llvm.fabs.f32(float %83)
  %86 = call float @llvm.fabs.f32(float %84)
  %87 = fcmp oge float %85, %86
  br i1 %87, label %complex_div_r_ge_s7, label %complex_div_r_lt_s8

complex_div_r_ge_s7:                              ; preds = %free_done6
  %88 = fdiv float %84, %83
  %89 = fmul float %84, %88
  %90 = fadd float %83, %89
  %91 = fmul float 0.000000e+00, %88
  %92 = fadd float 1.000000e+00, %91
  %93 = fmul float 1.000000e+00, %88
  %94 = fsub float 0.000000e+00, %93
  %95 = fdiv float %92, %90
  %96 = fdiv float %94, %90
  br label %complex_div_cont9

complex_div_r_lt_s8:                              ; preds = %free_done6
  %97 = fdiv float %83, %84
  %98 = fmul float %83, %97
  %99 = fadd float %84, %98
  %100 = fmul float 1.000000e+00, %97
  %101 = fadd float %100, 0.000000e+00
  %102 = fmul float 0.000000e+00, %97
  %103 = fsub float %102, 1.000000e+00
  %104 = fdiv float %101, %99
  %105 = fdiv float %103, %99
  br label %complex_div_cont9

complex_div_cont9:                                ; preds = %complex_div_r_lt_s8, %complex_div_r_ge_s7
  %106 = phi float [ %95, %complex_div_r_ge_s7 ], [ %104, %complex_div_r_lt_s8 ]
  %107 = phi float [ %96, %complex_div_r_ge_s7 ], [ %105, %complex_div_r_lt_s8 ]
  %108 = insertvalue %complex_4 undef, float %106, 0
  %109 = insertvalue %complex_4 %108, float %107, 1
  store %complex_4 %109, %complex_4* %x, align 1
  %110 = call i8* (i8*, i8*, i64, i8*, i64*, i32, i32, i32, i32, i32, ...) @_lcompilers_string_format_fortran(i8* %4, i8* null, i64 0, i8* getelementptr inbounds ([8 x i8], [8 x i8]* @serialization_info.2, i32 0, i32 0), i64* %2, i32 0, i32 0, i32 0, i32 0, i32 0, %complex_4* %x)
  %111 = load i64, i64* %2, align 8
  %112 = getelementptr %string_descriptor, %string_descriptor* %stringFormat_desc10, i32 0, i32 0
  store i8* %110, i8** %112, align 8
  %113 = getelementptr %string_descriptor, %string_descriptor* %stringFormat_desc10, i32 0, i32 1
  store i64 %111, i64* %113, align 8
  %114 = getelementptr %string_descriptor, %string_descriptor* %stringFormat_desc10, i32 0, i32 0
  %115 = load i8*, i8** %114, align 8
  %116 = getelementptr %string_descriptor, %string_descriptor* %stringFormat_desc10, i32 0, i32 1
  %117 = load i64, i64* %116, align 8
  %118 = trunc i64 %117 to i32
  call void @_lfortran_printf(i8* getelementptr inbounds ([5 x i8], [5 x i8]* @5, i32 0, i32 0), i8* %115, i32 %118, i8* getelementptr inbounds ([2 x i8], [2 x i8]* @4, i32 0, i32 0), i32 1)
  %119 = icmp eq i8* %110, null
  br i1 %119, label %free_done12, label %free_nonnull11

free_nonnull11:                                   ; preds = %complex_div_cont9
  call void @_lfortran_free_alloc(i8* %4, i8* %110)
  br label %free_done12

free_done12:                                      ; preds = %free_nonnull11, %complex_div_cont9
  br label %return

return:                                           ; preds = %free_done12
  br label %FINALIZE_SYMTABLE_complex2

FINALIZE_SYMTABLE_complex2:                       ; preds = %return
  call void @_lfortran_internal_alloc_finalize()
  ret i32 0
}

declare void @_lpython_call_initial_functions(i32, i8**)

; Function Attrs: nounwind readnone speculatable willreturn
declare float @llvm.fabs.f32(float) #0

declare i8* @_lcompilers_string_format_fortran(i8*, i8*, i64, i8*, i64*, i32, i32, i32, i32, i32, ...)

declare i8* @_lfortran_get_default_allocator()

