then4:                                            ; preds = %ifcont3
  call void (ptr, ...) @_lcompilers_print_error(ptr @7, ptr @"ERROR STOP", ptr @6)
  call void @_lfortran_internal_alloc_finalize()
  call void @exit(i32 1)
