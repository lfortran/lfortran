  %12 = getelementptr %string_descriptor, ptr %stringFormat_desc, i32 0, i32 1
  %13 = load i64, ptr %12, align 8
  %14 = trunc i64 %13 to i32
  call void @_lfortran_printf(ptr @3, ptr %11, i32 %14, ptr @2, i32 1)
