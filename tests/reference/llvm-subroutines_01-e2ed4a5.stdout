  %58 = getelementptr %string_descriptor, ptr %stringFormat_desc28, i32 0, i32 0
  %59 = load ptr, ptr %58, align 8
  %60 = getelementptr %string_descriptor, ptr %stringFormat_desc28, i32 0, i32 1
