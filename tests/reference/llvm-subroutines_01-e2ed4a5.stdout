else5:                                            ; preds = %ifcont3
  br label %ifcont6

ifcont6:                                          ; preds = %else5, %then4
  store i32 1, ptr %j, align 4
  %20 = load i32, ptr %j, align 4
  %21 = icmp ne i32 %20, 1
