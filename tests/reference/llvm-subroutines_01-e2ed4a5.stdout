  %51 = load i32, ptr %i, align 4
  %52 = add i32 %51, 2
  store i32 %52, ptr %call_arg_value, align 4
  call void @f(ptr %call_arg_value, ptr %j)
  %53 = alloca i64, align 8
  %54 = call ptr (ptr, i64, ptr, ptr, i32, i32, ...) @_lcompilers_string_format_fortran(ptr null, i64 0, ptr @serialization_info.3, ptr %53, i32 0, i32 0, ptr %j)
  %55 = load i64, ptr %53, align 4
  %stringFormat_desc28 = alloca %string_descriptor, align 8
  %56 = getelementptr %string_descriptor, ptr %stringFormat_desc28, i32 0, i32 0
