  %37 = alloca i64, align 8
  %38 = call ptr (ptr, ptr, i64, ptr, ptr, i32, i32, i32, i32, i32, ...) @_lcompilers_string_format_fortran(ptr %2, ptr null, i64 0, ptr @serialization_info.2, ptr %37, i32 0, i32 0, i32 0, i32 0, i32 0, ptr %j)
