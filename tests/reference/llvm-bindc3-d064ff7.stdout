; ModuleID = 'LFortran'
source_filename = "LFortran"

%string_descriptor = type <{ ptr, i64 }>

@bindc3.idx = internal global i32 1
@0 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@serialization_info = private unnamed_addr constant [10 x i8] c"CPtr,CPtr\00", align 1
@1 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1
@2 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@serialization_info.1 = private unnamed_addr constant [10 x i8] c"CPtr,CPtr\00", align 1
@3 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1

define i32 @main(i32 %0, ptr %1) {
.entry:
  call void @_lpython_call_initial_functions(i32 %0, ptr %1)
  %queries = alloca ptr, align 8
  %x = alloca ptr, align 8
  store ptr null, ptr %x, align 8
  %y = alloca i16, align 2
  %2 = load ptr, ptr %queries, align 8
  store ptr %2, ptr %x, align 8
  %3 = alloca i64, align 8
  %4 = load ptr, ptr %x, align 8
  %5 = alloca ptr, align 8
  store ptr %4, ptr %5, align 8
  %6 = call ptr (ptr, i64, ptr, ptr, i32, i32, ...) @_lcompilers_string_format_fortran(ptr null, i64 0, ptr @serialization_info, ptr %3, i32 0, i32 0, ptr %5, ptr %queries)
  %7 = load i64, ptr %3, align 4
  %stringFormat_desc = alloca %string_descriptor, align 8
  %8 = getelementptr %string_descriptor, ptr %stringFormat_desc, i32 0, i32 0
  store ptr %6, ptr %8, align 8
  %9 = getelementptr %string_descriptor, ptr %stringFormat_desc, i32 0, i32 1
  store i64 %7, ptr %9, align 4
  %10 = getelementptr %string_descriptor, ptr %stringFormat_desc, i32 0, i32 0
  %11 = load ptr, ptr %10, align 8
  %12 = getelementptr %string_descriptor, ptr %stringFormat_desc, i32 0, i32 1
  %13 = load i64, ptr %12, align 4
  %14 = trunc i64 %13 to i32
  call void @_lfortran_printf(ptr @1, ptr %11, i32 %14, ptr @0, i32 1)
  %15 = icmp eq ptr %6, null
  br i1 %15, label %free_done, label %free_nonnull

free_nonnull:                                     ; preds = %.entry
  call void @_lfortran_free(ptr %6)
  br label %free_done

free_done:                                        ; preds = %free_nonnull, %.entry
  store ptr %y, ptr %x, align 8
  %16 = alloca i64, align 8
  %17 = load ptr, ptr %x, align 8
  %18 = alloca ptr, align 8
  store ptr %17, ptr %18, align 8
  %19 = alloca ptr, align 8
  store ptr %y, ptr %19, align 8
  %20 = call ptr (ptr, i64, ptr, ptr, i32, i32, ...) @_lcompilers_string_format_fortran(ptr null, i64 0, ptr @serialization_info.1, ptr %16, i32 0, i32 0, ptr %18, ptr %19)
  %21 = load i64, ptr %16, align 4
  %stringFormat_desc1 = alloca %string_descriptor, align 8
  %22 = getelementptr %string_descriptor, ptr %stringFormat_desc1, i32 0, i32 0
  store ptr %20, ptr %22, align 8
  %23 = getelementptr %string_descriptor, ptr %stringFormat_desc1, i32 0, i32 1
  store i64 %21, ptr %23, align 4
  %24 = getelementptr %string_descriptor, ptr %stringFormat_desc1, i32 0, i32 0
  %25 = load ptr, ptr %24, align 8
  %26 = getelementptr %string_descriptor, ptr %stringFormat_desc1, i32 0, i32 1
  %27 = load i64, ptr %26, align 4
  %28 = trunc i64 %27 to i32
  call void @_lfortran_printf(ptr @3, ptr %25, i32 %28, ptr @2, i32 1)
  %29 = icmp eq ptr %20, null
  br i1 %29, label %free_done3, label %free_nonnull2

free_nonnull2:                                    ; preds = %free_done
  call void @_lfortran_free(ptr %20)
  br label %free_done3

free_done3:                                       ; preds = %free_nonnull2, %free_done
  call void @_lpython_free_argv()
  br label %return

return:                                           ; preds = %free_done3
  br label %FINALIZE_SYMTABLE_bindc3

FINALIZE_SYMTABLE_bindc3:                         ; preds = %return
  ret i32 0
}

declare void @_lpython_call_initial_functions(i32, ptr)

declare ptr @_lcompilers_string_format_fortran(ptr, i64, ptr, ptr, i32, i32, ...)

declare void @_lfortran_printf(ptr, ptr, i32, ptr, i32)

declare void @_lfortran_free(ptr)

declare void @_lpython_free_argv()
