else5:                                            ; preds = %ifcont3
  br label %ifcont6

ifcont6:                                          ; preds = %else5, %then4
  %99 = load %array*, %array** %c, align 8
  %100 = getelementptr %array, %array* %99, i32 0, i32 2
  %101 = load %dimension_descriptor*, %dimension_descriptor** %100, align 8
