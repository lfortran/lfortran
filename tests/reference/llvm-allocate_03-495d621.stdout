  %131 = add i32 %121, %130
  %132 = getelementptr %array, %array* %99, i32 0, i32 1
  %133 = load i32, i32* %132, align 4
  %134 = add i32 %131, %133
  %135 = getelementptr %array, %array* %99, i32 0, i32 0
  %136 = load i32*, i32** %135, align 8
  %137 = getelementptr inbounds i32, i32* %136, i32 %134
  store i32 8, i32* %137, align 4
