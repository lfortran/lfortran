  %114 = load i32, i32* %113, align 4
  %115 = getelementptr %dimension_descriptor, %dimension_descriptor* %112, i32 0, i32 2
  %116 = load i32, i32* %115, align 4
  %117 = sub i32 1, %114
  %118 = getelementptr %dimension_descriptor, %dimension_descriptor* %112, i32 0, i32 0
  %119 = load i32, i32* %118, align 4
  %120 = mul i32 %119, %117
  %121 = add i32 %111, %120
  %122 = getelementptr inbounds %dimension_descriptor, %dimension_descriptor* %101, i32 2
  %123 = getelementptr %dimension_descriptor, %dimension_descriptor* %122, i32 0, i32 1
  %124 = load i32, i32* %123, align 4
  %125 = getelementptr %dimension_descriptor, %dimension_descriptor* %122, i32 0, i32 2
  %126 = load i32, i32* %125, align 4
