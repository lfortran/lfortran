define i32 @main(i32 %0, i8** %1) {
.entry:
  %stringFormat_desc = alloca %string_descriptor, align 8
  %2 = alloca i32, align 4
  %3 = alloca i64, align 8
  %4 = call i8* @_lfortran_get_default_allocator()
  %arr_desc = alloca %array.3, align 8
  call void @_lpython_call_initial_functions(i32 %0, i8** %1)
  %c = alloca %array.3*, align 8
  store %array.3* null, %array.3** %c, align 8
  %5 = getelementptr %array.3, %array.3* %arr_desc, i32 0, i32 8
  %6 = getelementptr [3 x %dimension_descriptor], [3 x %dimension_descriptor]* %5, i32 0, i32 0
  %7 = getelementptr inbounds %dimension_descriptor, %dimension_descriptor* %6, i32 0
  %8 = getelementptr %dimension_descriptor, %dimension_descriptor* %7, i32 0, i32 0
  store i64 1, i64* %8, align 8
  %9 = getelementptr %dimension_descriptor, %dimension_descriptor* %7, i32 0, i32 1
  store i64 1, i64* %9, align 8
  %10 = getelementptr %dimension_descriptor, %dimension_descriptor* %7, i32 0, i32 2
  store i64 0, i64* %10, align 8
  %11 = getelementptr inbounds %dimension_descriptor, %dimension_descriptor* %6, i32 1
  %12 = getelementptr %dimension_descriptor, %dimension_descriptor* %11, i32 0, i32 0
  store i64 1, i64* %12, align 8
  %13 = getelementptr %dimension_descriptor, %dimension_descriptor* %11, i32 0, i32 1
  store i64 1, i64* %13, align 8
  %14 = getelementptr %dimension_descriptor, %dimension_descriptor* %11, i32 0, i32 2
  store i64 0, i64* %14, align 8
  %15 = getelementptr inbounds %dimension_descriptor, %dimension_descriptor* %6, i32 2
  %16 = getelementptr %dimension_descriptor, %dimension_descriptor* %15, i32 0, i32 0
  store i64 1, i64* %16, align 8
  %17 = getelementptr %dimension_descriptor, %dimension_descriptor* %15, i32 0, i32 1
  store i64 1, i64* %17, align 8
  %18 = getelementptr %dimension_descriptor, %dimension_descriptor* %15, i32 0, i32 2
  store i64 0, i64* %18, align 8
  %19 = getelementptr %array.3, %array.3* %arr_desc, i32 0, i32 3
  store i8 3, i8* %19, align 1
  %20 = getelementptr %array.3, %array.3* %arr_desc, i32 0, i32 0
  store i32* null, i32** %20, align 8
  store %array.3* %arr_desc, %array.3** %c, align 8
  %r = alloca i32, align 4
  %stat = alloca i32, align 4
  store i32 1, i32* %stat, align 4
  store i32 0, i32* %stat, align 4
  %21 = load %array.3*, %array.3** %c, align 8
  %22 = load %array.3*, %array.3** %c, align 8
  %23 = ptrtoint %array.3* %22 to i64
  %24 = icmp eq i64 %23, 0
  br i1 %24, label %merge_allocated, label %check_data

check_data:                                       ; preds = %.entry
