; ModuleID = 'LFortran'
source_filename = "LFortran"

%string_descriptor = type <{ ptr, i64 }>

@"ERROR STOP" = private unnamed_addr constant [11 x i8] c"ERROR STOP\00", align 1
@0 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@1 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1
@2 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@serialization_info = private unnamed_addr constant [3 x i8] c"I4\00", align 1
@3 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1
@4 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@5 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1
@6 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@serialization_info.1 = private unnamed_addr constant [3 x i8] c"I4\00", align 1
@7 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1
@8 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@9 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1
@10 = private unnamed_addr constant [2 x i8] c"\0A\00", align 1
@serialization_info.2 = private unnamed_addr constant [3 x i8] c"I4\00", align 1
@11 = private unnamed_addr constant [5 x i8] c"%s%s\00", align 1

define i32 @main(i32 %0, ptr %1) {
.entry:
  call void @_lpython_call_initial_functions(i32 %0, ptr %1)
  %i = alloca i32, align 4
  %j = alloca i32, align 4
  store i32 0, ptr %j, align 4
  store i32 0, ptr %i, align 4
  br label %loop.head

loop.head:                                        ; preds = %ifcont3, %.entry
  %2 = load i32, ptr %i, align 4
  %3 = add i32 %2, 1
  %4 = icmp sle i32 %3, 10
  br i1 %4, label %loop.body, label %loop.end

loop.body:                                        ; preds = %loop.head
  %5 = load i32, ptr %i, align 4
  %6 = add i32 %5, 1
  store i32 %6, ptr %i, align 4
  %7 = load i32, ptr %j, align 4
  %8 = load i32, ptr %i, align 4
  %9 = add i32 %7, %8
  store i32 %9, ptr %j, align 4
  %10 = load i32, ptr %i, align 4
  %11 = icmp eq i32 %10, 3
  br i1 %11, label %then, label %else

then:                                             ; preds = %loop.body
  br label %ifcont

else:                                             ; preds = %loop.body
  br label %ifcont

ifcont:                                           ; preds = %else, %then
  %12 = load i32, ptr %i, align 4
  %13 = icmp eq i32 %12, 2
  br i1 %13, label %then1, label %else2

then1:                                            ; preds = %ifcont
  br label %loop.end

unreachable_after_exit:                           ; No predecessors!
  br label %ifcont3

else2:                                            ; preds = %ifcont
  br label %ifcont3

ifcont3:                                          ; preds = %else2, %unreachable_after_exit
  br label %loop.head

loop.end:                                         ; preds = %then1, %loop.head
  %14 = load i32, ptr %j, align 4
  %15 = icmp ne i32 %14, 3
  br i1 %15, label %then4, label %else5

then4:                                            ; preds = %loop.end
  call void (ptr, ...) @_lcompilers_print_error(ptr @1, ptr @"ERROR STOP", ptr @0)
  call void @exit(i32 1)
  br label %ifcont6

else5:                                            ; preds = %loop.end
  br label %ifcont6

ifcont6:                                          ; preds = %else5, %then4
  %16 = alloca i64, align 8
  %17 = call ptr (ptr, i64, ptr, ptr, i32, i32, ...) @_lcompilers_string_format_fortran(ptr null, i64 0, ptr @serialization_info, ptr %16, i32 0, i32 0, ptr %j)
  %18 = load i64, ptr %16, align 4
  %stringFormat_desc = alloca %string_descriptor, align 8
  %19 = getelementptr %string_descriptor, ptr %stringFormat_desc, i32 0, i32 0
  store ptr %17, ptr %19, align 8
  %20 = getelementptr %string_descriptor, ptr %stringFormat_desc, i32 0, i32 1
  store i64 %18, ptr %20, align 4
  %21 = getelementptr %string_descriptor, ptr %stringFormat_desc, i32 0, i32 0
  %22 = load ptr, ptr %21, align 8
  %23 = getelementptr %string_descriptor, ptr %stringFormat_desc, i32 0, i32 1
  %24 = load i64, ptr %23, align 4
  %25 = trunc i64 %24 to i32
  call void @_lfortran_printf(ptr @3, ptr %22, i32 %25, ptr @2, i32 1)
  %26 = icmp eq ptr %17, null
  br i1 %26, label %free_done, label %free_nonnull

free_nonnull:                                     ; preds = %ifcont6
  call void @_lfortran_free(ptr %17)
  br label %free_done

free_done:                                        ; preds = %free_nonnull, %ifcont6
  store i32 0, ptr %j, align 4
  store i32 0, ptr %i, align 4
  br label %loop.head7

loop.head7:                                       ; preds = %ifcont12, %free_done
  %27 = load i32, ptr %i, align 4
  %28 = add i32 %27, 1
  %29 = icmp sle i32 %28, 10
  br i1 %29, label %loop.body8, label %loop.end13

loop.body8:                                       ; preds = %loop.head7
  %30 = load i32, ptr %i, align 4
  %31 = add i32 %30, 1
  store i32 %31, ptr %i, align 4
  %32 = load i32, ptr %i, align 4
  %33 = icmp eq i32 %32, 2
  br i1 %33, label %then9, label %else11

then9:                                            ; preds = %loop.body8
  br label %loop.end13

unreachable_after_exit10:                         ; No predecessors!
  br label %ifcont12

else11:                                           ; preds = %loop.body8
  br label %ifcont12

ifcont12:                                         ; preds = %else11, %unreachable_after_exit10
  %34 = load i32, ptr %j, align 4
  %35 = load i32, ptr %i, align 4
  %36 = add i32 %34, %35
  store i32 %36, ptr %j, align 4
  br label %loop.head7

loop.end13:                                       ; preds = %then9, %loop.head7
  %37 = load i32, ptr %j, align 4
  %38 = icmp ne i32 %37, 1
  br i1 %38, label %then14, label %else15

then14:                                           ; preds = %loop.end13
  call void (ptr, ...) @_lcompilers_print_error(ptr @5, ptr @"ERROR STOP", ptr @4)
  call void @exit(i32 1)
  br label %ifcont16

else15:                                           ; preds = %loop.end13
  br label %ifcont16

ifcont16:                                         ; preds = %else15, %then14
  %39 = alloca i64, align 8
  %40 = call ptr (ptr, i64, ptr, ptr, i32, i32, ...) @_lcompilers_string_format_fortran(ptr null, i64 0, ptr @serialization_info.1, ptr %39, i32 0, i32 0, ptr %j)
  %41 = load i64, ptr %39, align 4
  %stringFormat_desc17 = alloca %string_descriptor, align 8
  %42 = getelementptr %string_descriptor, ptr %stringFormat_desc17, i32 0, i32 0
  store ptr %40, ptr %42, align 8
  %43 = getelementptr %string_descriptor, ptr %stringFormat_desc17, i32 0, i32 1
  store i64 %41, ptr %43, align 4
  %44 = getelementptr %string_descriptor, ptr %stringFormat_desc17, i32 0, i32 0
  %45 = load ptr, ptr %44, align 8
  %46 = getelementptr %string_descriptor, ptr %stringFormat_desc17, i32 0, i32 1
  %47 = load i64, ptr %46, align 4
  %48 = trunc i64 %47 to i32
  call void @_lfortran_printf(ptr @7, ptr %45, i32 %48, ptr @6, i32 1)
  %49 = icmp eq ptr %40, null
  br i1 %49, label %free_done19, label %free_nonnull18

free_nonnull18:                                   ; preds = %ifcont16
  call void @_lfortran_free(ptr %40)
  br label %free_done19

free_done19:                                      ; preds = %free_nonnull18, %ifcont16
  store i32 0, ptr %j, align 4
  store i32 0, ptr %i, align 4
  br label %loop.head20

loop.head20:                                      ; preds = %ifcont24, %then22, %free_done19
  %50 = load i32, ptr %i, align 4
  %51 = add i32 %50, 1
  %52 = icmp sle i32 %51, 10
  br i1 %52, label %loop.body21, label %loop.end25

loop.body21:                                      ; preds = %loop.head20
  %53 = load i32, ptr %i, align 4
  %54 = add i32 %53, 1
  store i32 %54, ptr %i, align 4
  %55 = load i32, ptr %i, align 4
  %56 = icmp eq i32 %55, 2
  br i1 %56, label %then22, label %else23

then22:                                           ; preds = %loop.body21
  br label %loop.head20

unreachable_after_cycle:                          ; No predecessors!
  br label %ifcont24

else23:                                           ; preds = %loop.body21
  br label %ifcont24

ifcont24:                                         ; preds = %else23, %unreachable_after_cycle
  %57 = load i32, ptr %j, align 4
  %58 = load i32, ptr %i, align 4
  %59 = add i32 %57, %58
  store i32 %59, ptr %j, align 4
  br label %loop.head20

loop.end25:                                       ; preds = %loop.head20
  %60 = load i32, ptr %j, align 4
  %61 = icmp ne i32 %60, 53
  br i1 %61, label %then26, label %else27

then26:                                           ; preds = %loop.end25
  call void (ptr, ...) @_lcompilers_print_error(ptr @9, ptr @"ERROR STOP", ptr @8)
  call void @exit(i32 1)
  br label %ifcont28

else27:                                           ; preds = %loop.end25
  br label %ifcont28

ifcont28:                                         ; preds = %else27, %then26
  %62 = alloca i64, align 8
  %63 = call ptr (ptr, i64, ptr, ptr, i32, i32, ...) @_lcompilers_string_format_fortran(ptr null, i64 0, ptr @serialization_info.2, ptr %62, i32 0, i32 0, ptr %j)
  %64 = load i64, ptr %62, align 4
  %stringFormat_desc29 = alloca %string_descriptor, align 8
  %65 = getelementptr %string_descriptor, ptr %stringFormat_desc29, i32 0, i32 0
  store ptr %63, ptr %65, align 8
  %66 = getelementptr %string_descriptor, ptr %stringFormat_desc29, i32 0, i32 1
  store i64 %64, ptr %66, align 4
  %67 = getelementptr %string_descriptor, ptr %stringFormat_desc29, i32 0, i32 0
  %68 = load ptr, ptr %67, align 8
  %69 = getelementptr %string_descriptor, ptr %stringFormat_desc29, i32 0, i32 1
  %70 = load i64, ptr %69, align 4
  %71 = trunc i64 %70 to i32
  call void @_lfortran_printf(ptr @11, ptr %68, i32 %71, ptr @10, i32 1)
  %72 = icmp eq ptr %63, null
  br i1 %72, label %free_done31, label %free_nonnull30

free_nonnull30:                                   ; preds = %ifcont28
  call void @_lfortran_free(ptr %63)
  br label %free_done31

free_done31:                                      ; preds = %free_nonnull30, %ifcont28
  call void @_lpython_free_argv()
  br label %return

return:                                           ; preds = %free_done31
  br label %FINALIZE_SYMTABLE_doloop_03

FINALIZE_SYMTABLE_doloop_03:                      ; preds = %return
  ret i32 0
}

declare void @_lpython_call_initial_functions(i32, ptr)

declare void @_lcompilers_print_error(ptr, ...)

declare void @exit(i32)

declare ptr @_lcompilers_string_format_fortran(ptr, i64, ptr, ptr, i32, i32, ...)

declare void @_lfortran_printf(ptr, ptr, i32, ptr, i32)

declare void @_lfortran_free(ptr)

declare void @_lpython_free_argv()
