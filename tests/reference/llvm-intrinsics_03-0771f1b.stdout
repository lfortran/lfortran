  %r1 = alloca double, align 8
  %r2 = alloca double, align 8
  %x = alloca float, align 4
  store double 4.200000e+00, double* %a, align 8
  store float 0xBFEFE8D5A0000000, float* %x, align 4
  %5 = load float, float* %x, align 4
  %6 = fadd float %5, 0x3FEFE8D5A0000000
  %7 = call float @llvm.fabs.f32(float %6)
  %8 = fcmp ogt float %7, 0x3E7AD7F2A0000000
  br i1 %8, label %then, label %else

then:                                             ; preds = %.entry
  call void (i8*, ...) @_lcompilers_print_error(i8* getelementptr inbounds ([5 x i8], [5 x i8]* @1, i32 0, i32 0), i8* getelementptr inbounds ([11 x i8], [11 x i8]* @"ERROR STOP", i32 0, i32 0), i8* getelementptr inbounds ([2 x i8], [2 x i8]* @0, i32 0, i32 0))
  call void @_lfortran_internal_alloc_finalize()
  call void @exit(i32 1)
  br label %ifcont

else:                                             ; preds = %.entry
  br label %ifcont

ifcont:                                           ; preds = %else, %then
  %9 = call double @_lcompilers_cos_f64(double* %a)
  %10 = fadd double %9, 0x3FDF606EE0000000
  %11 = call double @llvm.fabs.f64(double %10)
  %12 = fcmp ogt double %11, 0x3E7AD7F2A0000000
