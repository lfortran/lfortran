else2:                                            ; preds = %ifcont
  br label %ifcont3

ifcont3:                                          ; preds = %else2, %then1
  %13 = load double, double* %a, align 8
  %14 = call double @_lcompilers_cos_f64(double* %a)
  %15 = fadd double %13, %14
  store double %15, double* %call_arg_value, align 8
  %16 = call double @_lcompilers_cos_f64(double* %call_arg_value)
  %17 = fadd double 0x3FB21BD54FC5F9A7, %16
  store double %17, double* %call_arg_value4, align 8
  %18 = call double @_lcompilers_cos_f64(double* %call_arg_value4)
  %19 = fsub double %18, 0x3FE6ECC720000000
  %20 = call double @llvm.fabs.f64(double %19)
  %21 = fcmp ogt double %20, 0x3E7AD7F2A0000000
  br i1 %21, label %then5, label %else6

then5:                                            ; preds = %ifcont3
  call void (i8*, ...) @_lcompilers_print_error(i8* getelementptr inbounds ([5 x i8], [5 x i8]* @5, i32 0, i32 0), i8* getelementptr inbounds ([11 x i8], [11 x i8]* @"ERROR STOP", i32 0, i32 0), i8* getelementptr inbounds ([2 x i8], [2 x i8]* @4, i32 0, i32 0))
  call void @_lfortran_internal_alloc_finalize()
  call void @exit(i32 1)
  br label %ifcont7

else6:                                            ; preds = %ifcont3
  br label %ifcont7

ifcont7:                                          ; preds = %else6, %then5
  %22 = call double @_lcompilers_cos_f64(double* %a)
  store double %22, double* %r1, align 8
  store double 0xBFDF606EEC8AC71E, double* %r2, align 8
  %23 = load double, double* %r1, align 8
  %24 = load double, double* %r2, align 8
  %25 = fsub double %23, %24
  %26 = call double @llvm.fabs.f64(double %25)
  %27 = fcmp ogt double %26, 1.000000e-15
  br i1 %27, label %then8, label %else9

then8:                                            ; preds = %ifcont7
  call void (i8*, ...) @_lcompilers_print_error(i8* getelementptr inbounds ([5 x i8], [5 x i8]* @7, i32 0, i32 0), i8* getelementptr inbounds ([11 x i8], [11 x i8]* @"ERROR STOP", i32 0, i32 0), i8* getelementptr inbounds ([2 x i8], [2 x i8]* @6, i32 0, i32 0))
  call void @_lfortran_internal_alloc_finalize()
  call void @exit(i32 1)
